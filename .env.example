DEBUG=True
SECRET_KEY=changeme-in-production-use-django-secret-key-generator
ALLOWED_HOSTS=localhost,127.0.0.1

# Clé de signature JWT — DOIT être distincte de SECRET_KEY en production.
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SIGNING_KEY=changeme-generate-a-strong-jwt-signing-key

# Origines CORS autorisées (séparées par des virgules).
# Le mobile React Native n'est pas un navigateur, CORS ne le concerne pas.
# Ne lister ici que les frontends web (ex: app superviseur en prod).
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

DB_NAME=sodigaz_poc
DB_USER=sodigaz
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5433

# Code d'acces au mode developpeur mobile.
# Generer une valeur forte : python3 -c "import secrets; print(secrets.token_urlsafe(12))"
# Ne jamais commiter la valeur reelle dans git (ce fichier est un exemple).
DEV_ACCESS_CODE=changeme-generate-a-strong-random-code
